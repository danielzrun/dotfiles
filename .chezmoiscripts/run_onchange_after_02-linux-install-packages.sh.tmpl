{{- if eq .chezmoi.os "linux" -}}
#!/bin/bash
# =============================================================================
# Debian-based Apt Package Installation
# =============================================================================
# This script runs when Aptfile hash changes (via run_onchange_ prefix)
# Supports: Debian, Ubuntu, Linux Mint, Pop!_OS, and other deb-based distros
# Hash: {{ include "dot_config/debian/Aptfile" | sha256sum }}

set -euo pipefail

echo "📦 Installing Debian-based packages from Aptfile..."
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

sudo apt-get update

# Install packages from Aptfile (filter comments and empty lines)
grep -v '^#' {{ .chezmoi.sourceDir }}/dot_config/debian/Aptfile | grep -v '^$' | xargs sudo apt-get install -y

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
echo "✅ Apt packages installed!"

{{- end -}}
