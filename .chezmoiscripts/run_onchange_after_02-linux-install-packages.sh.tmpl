{{- if eq .chezmoi.os "linux" -}}
#!/bin/bash
# =============================================================================
# Ubuntu Apt Package Installation
# =============================================================================
# This script runs when Aptfile hash changes (via run_onchange_ prefix)
# Hash: {{ include "dot_config/ubuntu/Aptfile" | sha256sum }}

set -euo pipefail

echo "📦 Installing Ubuntu packages from Aptfile..."
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# Ensure universe repo is enabled
sudo add-apt-repository universe -y 2>/dev/null || true
sudo apt-get update

# Install packages from Aptfile
xargs -a {{ .chezmoi.sourceDir }}/dot_config/ubuntu/Aptfile sudo apt-get install -y

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
echo "✅ Apt packages installed!"

{{- end -}}
