{{- if eq .chezmoi.os "linux" -}}
#!/bin/bash
# =============================================================================
# Debian-based Essential Packages Installation
# =============================================================================
# Runs only once on first chezmoi apply (via run_once_ prefix)
# Installs zsh, git, nvm required for dotfiles setup
# Supports: Debian, Ubuntu, Linux Mint, Pop!_OS, and other deb-based distros

set -euo pipefail

echo "📦 Installing essential Debian-based packages (zsh, git, unzip, nvm)..."

# Detect Debian-based distributions
if [ ! -f /etc/os-release ]; then
    echo "⚠️  Cannot detect OS distribution"
    exit 1
fi

# Source os-release to get ID and VERSION_ID
. /etc/os-release

# Check version requirements: Debian 13+ or Ubuntu 24.04+
case "$ID" in
    debian)
        # Require Debian 13+
        if [ "${VERSION_ID%%.*}" -lt 13 ]; then
            echo "⚠️  Debian 13+ required, found $VERSION_ID"
            exit 1
        fi
        ;;
    ubuntu)
        # Require Ubuntu 24.04+
        UB_MAJOR=${VERSION_ID%%.*}
        UB_MINOR=${VERSION_ID#*.}
        if [ "$UB_MAJOR" -lt 24 ] || { [ "$UB_MAJOR" -eq 24 ] && [ "${UB_MINOR%%.*}" -lt 04 ]; }; then
            echo "⚠️  Ubuntu 24.04+ required, found $VERSION_ID"
            exit 1
        fi
        ;;
    *)
        # Other Debian-based distros: check ID_LIKE
        if [[ "$ID_LIKE" != *"debian"* ]]; then
            echo "⚠️  This script only supports Debian 13+ or Ubuntu 24.04+"
            exit 1
        fi
        ;;
esac

# Check and install packages separately
PACKAGES=""

if ! command -v zsh >/dev/null 2>&1; then
    PACKAGES="$PACKAGES zsh"
fi

if ! command -v git >/dev/null 2>&1; then
    PACKAGES="$PACKAGES git"
fi

if ! command -v unzip >/dev/null 2>&1; then
    PACKAGES="$PACKAGES unzip"
fi

# Update package list and install
sudo apt-get update
# shellcheck disable=SC2086
sudo apt-get install -y $PACKAGES

# Install nvm (Node Version Manager) + Node.js 24
# Uses XDG-compliant path: ~/.config/nvm (or ~/.nvm as fallback)
NVM_INSTALL_DIR="${NVM_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/nvm}"

if [ ! -d "$NVM_INSTALL_DIR" ]; then
    echo ""
    echo "📦 Installing nvm v0.40.4..."
    curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.4/install.sh | bash

    # Set NVM_DIR and install Node.js 24
    export NVM_DIR="$NVM_INSTALL_DIR"
    if [ -s "$NVM_DIR/nvm.sh" ]; then
        bash -c ". \"$NVM_DIR/nvm.sh\" && nvm install 24 && nvm alias default 24"
        echo "  ✓ nvm installed to $NVM_INSTALL_DIR"
        echo "  ✓ Node.js 24 installed as default"
    else
        echo "  ⚠️  nvm.sh not found, skipping Node.js installation"
    fi
else
    echo "✓ nvm already installed at $NVM_INSTALL_DIR"
    # Ensure Node.js 24 is installed
    export NVM_DIR="$NVM_INSTALL_DIR"
    if [ -s "$NVM_DIR/nvm.sh" ]; then
        if ! bash -c ". \"$NVM_DIR/nvm.sh\" && nvm list 24" >/dev/null 2>&1; then
            bash -c ". \"$NVM_DIR/nvm.sh\" && nvm install 24 && nvm alias default 24"
            echo "  ✓ Node.js 24 installed as default"
        fi
    fi
fi

echo "✅ Essential packages installed!"
{{- end -}}
