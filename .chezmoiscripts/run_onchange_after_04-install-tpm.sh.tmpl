#!/usr/bin/env bash
# =============================================================================
# Install TPM (Tmux Plugin Manager)
# =============================================================================
# This script automatically installs TPM if not present
# Triggers on changes to tmux config
# hash: {{ include "dot_config/tmux/tmux.conf.tmpl" | sha256sum }}

set -euo pipefail

TPM_DIR="{{ .chezmoi.homeDir }}/.config/tmux/plugins/tpm"

if [ ! -d "$TPM_DIR" ]; then
    echo "📦 Installing TPM (Tmux Plugin Manager)..."
    mkdir -p "$(dirname "$TPM_DIR")"
    git clone https://github.com/tmux-plugins/tpm "$TPM_DIR"
    echo "✓ TPM installed to $TPM_DIR"
else
    echo "✓ TPM already installed"
fi

# Install plugins automatically
echo ""
echo "📦 Installing tmux plugins..."
"$TPM_DIR/bin/install_plugins" || echo "⚠ Some plugins may need manual install"
echo "✓ Plugins installed"
