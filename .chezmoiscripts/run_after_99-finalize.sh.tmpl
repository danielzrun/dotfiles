#!/bin/bash
# =============================================================================
# Setup Final Check
# =============================================================================
# This script runs LAST after all other scripts on every chezmoi apply
# Provides status reminders and next steps

set -euo pipefail

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "✅ Dotfiles setup complete!"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# Rebuild bat theme cache (for custom themes like Catppuccin)
# Note: Debian/Ubuntu installs as 'batcat', macOS as 'bat'
BAT_CMD="bat"
if ! command -v bat >/dev/null 2>&1 && command -v batcat >/dev/null 2>&1; then
    BAT_CMD="batcat"
fi

if command -v "$BAT_CMD" >/dev/null 2>&1; then
    "$BAT_CMD" cache --build &>/dev/null
    echo "✓ Bat theme cache updated"
fi

echo "Next steps:"
echo "  • Restart your shell or run: zsh"
echo ""
