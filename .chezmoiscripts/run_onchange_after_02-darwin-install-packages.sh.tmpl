{{- if eq .chezmoi.os "darwin" -}}
#!/bin/bash
# =============================================================================
# Homebrew Package Installation (macOS only)
# =============================================================================
# This script runs when Brewfile hash changes (via run_onchange_ prefix)
# Hash: {{ include "dot_config/brew/Brewfile" | sha256sum }}

set -euo pipefail

# Sync packages from Brewfile
echo "📦 Syncing Homebrew packages from Brewfile..."
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
brew bundle --file={{ .chezmoi.sourceDir }}/dot_config/brew/Brewfile
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

echo ""
echo "✅ Brewfile packages synced!"
{{- end -}}


