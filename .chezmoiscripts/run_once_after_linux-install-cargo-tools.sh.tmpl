{{- if eq .chezmoi.os "linux" -}}
#!/bin/bash
# =============================================================================
# Cargo Tools Installation (Linux)
# =============================================================================
# Runs once on first chezmoi apply (via run_once_ prefix)
# Installs Rust cargo and useful Rust tools

set -euo pipefail

echo "🦀 Installing Rust cargo and tools..."

# Install Rust/Cargo if not present
if ! command -v cargo >/dev/null 2>&1; then
    echo "📥 Installing Rust..."
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh
    # Source cargo env for current session
    source "$HOME/.cargo/env"
else
    echo "✓ Rust already installed"
fi

# Rust tools to install
CARGO_TOOLS="
    carapace
    sd
    procs
    difftastic
    jaq
    fx
    jless
    jnv
    ast-grep
    hyperfine
    just
    xh
    gping
"

# Install each tool if not already installed
for tool in $CARGO_TOOLS; do
    if cargo install --list | grep -q "^$tool "; then
        echo "  ✓ $tool already installed"
    else
        echo "  📦 Installing $tool..."
        cargo install $tool || echo "  ⚠️  Failed to install $tool"
    fi
done

echo ""
echo "✅ Cargo tools installed!"
echo "   Note: Run 'source ~/.cargo/env' or restart your shell to use them."

{{- end -}}
