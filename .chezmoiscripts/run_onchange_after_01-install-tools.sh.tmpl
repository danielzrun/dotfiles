#!/bin/bash
# =============================================================================
# Essential Tools Installation
# =============================================================================
# This script runs when its content changes (via run_onchange_ prefix)
# Use this for tools that should be kept up-to-date with config changes
# Hash: {{ include ".chezmoiscripts/run_onchange_after_01-install-tools.sh.tmpl" | sha256sum }}

set -euo pipefail

# Ensure PATH includes user binaries for tool detection
export PATH="$HOME/.local/bin:$PATH"

{{ if eq .chezmoi.os "darwin" -}}
# Install Homebrew (macOS only)
if ! command -v brew >/dev/null 2>&1; then
    echo "⚠️  Homebrew not found. Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

    # Add Homebrew to PATH for current session
    if [[ -d "/opt/homebrew" ]]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
    elif [[ -d "/usr/local/bin/brew" ]]; then
        eval "$(/usr/local/bin/brew shellenv)"
    fi
fi
{{- end }}

# Install Claude Code via native script
if ! command -v claude >/dev/null 2>&1; then
    echo ""
    echo "📦 Installing Claude Code via native installer..."
    curl -fsSL https://claude.ai/install.sh | bash
else
    echo "✓ Claude Code already installed"
fi

# Install Bun
if ! command -v bun >/dev/null 2>&1; then
    echo ""
    echo "📦 Installing Bun..."
    # Pretend to be bash to prevent modifying .zshrc
    SHELL=/bin/bash bash -c 'curl -fsSL https://bun.sh/install | bash'
else
    echo "✓ Bun already installed"
fi

#(Linux only)
{{ if eq .chezmoi.os "linux" -}}
# Detect system architecture
ARCH=$(uname -m)
# Neovim uses arm64 (not aarch64) for ARM builds
[ "$ARCH" = "aarch64" ] && NVIM_ARCH="arm64" || NVIM_ARCH="x86_64"

# Install starship
if ! command -v starship >/dev/null 2>&1; then
    echo ""
    echo "📦 Installing starship..."
    sudo curl -sS https://starship.rs/install.sh | sh -s -- -y
else
    echo "✓ starship already installed"
fi

# Install atuin
if ! command -v atuin >/dev/null 2>&1; then
    echo ""
    echo "📦 Installing atuin..."
    curl --proto '=https' --tlsv1.2 -LsSf https://setup.atuin.sh | sh -s -- --non-interactive
    # Link atuin to ~/.local/bin for PATH access
    ln -sf ~/.atuin/bin/atuin ~/.local/bin/atuin
else
    echo "✓ atuin already installed"
fi

# Install neovim latest (Linux only)
LATEST_VERSION=$(curl -s https://api.github.com/repos/neovim/neovim/releases/latest | grep '"tag_name"' | sed -E 's/.*"([^"]+)".*/\1/' | sed 's/v//')
CURRENT_VERSION=$(command -v nvim >/dev/null 2>&1 && nvim --version | grep -oP 'NVIM v\K[0-9.]+' || echo "none")

if [ "$CURRENT_VERSION" != "$LATEST_VERSION" ]; then
    echo ""
    if [ "$CURRENT_VERSION" != "none" ]; then
        echo "  Updating neovim $CURRENT_VERSION -> $LATEST_VERSION..."
    else
        echo "  Installing neovim $LATEST_VERSION..."
    fi
    sudo apt-get remove -y neovim 2>/dev/null || true
    # Remove old installation
    rm -rf ~/.local/nvim-*
    # Download and extract
    curl -sL "https://github.com/neovim/neovim/releases/latest/download/nvim-linux-${NVIM_ARCH}.tar.gz" | tar -xzf - -C ~/.local
    # Find extracted directory (all neovim builds use nvim-linux64)
    NVIM_DIR=$(find ~/.local -maxdepth 1 -type d -name "nvim-*" | head -1)
    rm -f ~/.local/bin/nvim
    ln -sf ${NVIM_DIR}/bin/nvim ~/.local/bin/nvim
    echo "  ✓ neovim $LATEST_VERSION installed"
fi

# Install yazi (Linux only)
if ! command -v yazi >/dev/null 2>&1; then
    echo ""
    echo "📦 Installing yazi..."
    # Download to temp file first (yazi releases use .zip format)
    TEMP_ZIP=$(mktemp)
    trap "rm -f $TEMP_ZIP" EXIT
    YAZI_URL="https://github.com/sxyazi/yazi/releases/latest/download/yazi-${ARCH}-unknown-linux-gnu.zip"
    echo "  Downloading from: $YAZI_URL"
    if ! curl -fsSL "$YAZI_URL" -o "$TEMP_ZIP"; then
        echo "  ⚠️  Failed to download yazi. Please check your internet connection."
        echo "  You can install manually: cargo install yazi"
        exit 1
    fi
    # Verify it's a zip file
    if ! file "$TEMP_ZIP" | grep -q Zip; then
        echo "  ⚠️  Downloaded file is not a valid zip archive."
        echo "  The URL may be incorrect or GitHub may be rate limiting."
        echo "  You can install manually: cargo install yazi"
        exit 1
    fi
    # Extract yazi binary directly
    unzip -q -o "$TEMP_ZIP" -d ~/.local
    # Create symlink (yazi zip extracts the binary directly, not in a subdirectory)
    rm -f ~/.local/bin/yazi
    ln -sf ~/.local/yazi ~/.local/bin/yazi
    echo "  ✓ yazi installed"
else
    echo "✓ yazi already installed"
fi

# Install eza (modern ls replacement)
if ! command -v eza >/dev/null 2>&1; then
    echo ""
    echo "📦 Installing eza..."
    # Download latest release
    EZA_URL="https://github.com/eza-community/eza/releases/latest/download/eza_${ARCH}-unknown-linux-gnu.tar.gz"
    TEMP_TAR=$(mktemp)
    trap "rm -f $TEMP_TAR" EXIT
    if ! curl -fsSL "$EZA_URL" -o "$TEMP_TAR"; then
        echo "  ⚠️  Failed to download eza. Install manually: cargo install eza"
        exit 1
    fi
    if ! file "$TEMP_TAR" | grep -q gzip; then
        echo "  ⚠️  Downloaded file is not valid. Install manually: cargo install eza"
        exit 1
    fi
    tar -xzf "$TEMP_TAR" -C ~/.local
    rm -f ~/.local/bin/eza
    ln -sf ~/.local/eza ~/.local/bin/eza
    echo "  ✓ eza installed"
else
    echo "✓ eza already installed"
fi

# Install git-delta (syntax-highlighting pager for git)
if ! command -v delta >/dev/null 2>&1; then
    echo ""
    echo "📦 Installing git-delta..."
    # Get download URL from API (filename includes version)
    DELTA_URL=$(curl -s https://api.github.com/repos/dandavison/delta/releases/latest | grep -o '"browser_download_url": *"[^"]*'${ARCH}'-unknown-linux-gnu\.tar\.gz"' | sed -E 's/.*"([^"]+)".*/\1/')
    TEMP_TAR=$(mktemp)
    trap "rm -f $TEMP_TAR" EXIT
    if ! curl -fsSL "$DELTA_URL" -o "$TEMP_TAR"; then
        echo "  ⚠️  Failed to download delta. Install manually: cargo install git-delta"
        exit 1
    fi
    if ! file "$TEMP_TAR" | grep -q gzip; then
        echo "  ⚠️  Downloaded file is not valid. Install manually: cargo install git-delta"
        exit 1
    fi
    # Delta tar extracts to a directory with version in name
    tar -xzf "$TEMP_TAR" -C ~/.local
    rm -f ~/.local/bin/delta
    # Find the extracted delta directory
    DELTA_DIR=$(find ~/.local -maxdepth 1 -type d -name "delta-*" | head -1)
    ln -sf ${DELTA_DIR}/delta ~/.local/bin/delta
    echo "  ✓ git-delta installed"
else
    echo "✓ git-delta already installed"
fi

# Install just (command runner)
if ! command -v just >/dev/null 2>&1; then
    echo ""
    echo "📦 Installing just..."
    # Get download URL from API (filename includes version, uses musl)
    JUST_URL=$(curl -s https://api.github.com/repos/casey/just/releases/latest | grep -o '"browser_download_url": *"[^"]*'${ARCH}'-unknown-linux-musl\.tar\.gz"' | sed -E 's/.*"([^"]+)".*/\1/')
    TEMP_TAR=$(mktemp)
    trap "rm -f $TEMP_TAR" EXIT
    if ! curl -fsSL "$JUST_URL" -o "$TEMP_TAR"; then
        echo "  ⚠️  Failed to download just. Install manually: cargo install just"
        exit 1
    fi
    if ! file "$TEMP_TAR" | grep -q gzip; then
        echo "  ⚠️  Downloaded file is not valid. Install manually: cargo install just"
        exit 1
    fi
    # Just tar extracts directly to the binary
    tar -xzf "$TEMP_TAR" -C ~/.local/bin
    echo "  ✓ just installed"
else
    echo "✓ just already installed"
fi
{{- end }}

echo ""
echo "✅ Essential tools synced!"
