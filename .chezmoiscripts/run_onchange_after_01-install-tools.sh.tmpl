#!/bin/bash
# =============================================================================
# Essential Tools Installation
# =============================================================================
# This script runs when its content changes (via run_onchange_ prefix)
# Use this for tools that should be kept up-to-date with config changes
# Hash: {{ include ".chezmoiscripts/run_onchange_after_01-install-tools.sh.tmpl" | sha256sum }}

{{ if eq .chezmoi.os "darwin" -}}
# Install Homebrew (macOS only)
if ! command -v brew >/dev/null 2>&1; then
    echo "⚠️  Homebrew not found. Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

    # Add Homebrew to PATH for current session
    if [[ -d "/opt/homebrew" ]]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
    elif [[ -d "/usr/local/bin/brew" ]]; then
        eval "$(/usr/local/bin/brew shellenv)"
    fi
fi
{{- end }}

# Install Oh My Zsh if not present
if [ ! -d "$HOME/.oh-my-zsh" ]; then
    echo "📥 Installing Oh My Zsh..."
    sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended
    echo "✅ Oh My Zsh installed"
fi

# Install Oh My Zsh plugins
PLUGINS_DIR="$HOME/.oh-my-zsh/custom/plugins"

install_plugin() {
    local name=$1
    local repo=$2
    local target="$PLUGINS_DIR/$name"

    if [ ! -d "$target" ]; then
        echo "📥 Installing plugin: $name..."
        git clone --depth=1 "$repo" "$target"
    else
        echo "✓ Plugin already installed: $name"
    fi
}

echo ""
echo "📦 Installing Oh My Zsh plugins..."
install_plugin "zsh-autosuggestions" "https://github.com/zsh-users/zsh-autosuggestions"
install_plugin "zsh-completions" "https://github.com/zsh-users/zsh-completions"
install_plugin "fzf-tab" "https://github.com/Aloxaf/fzf-tab"
install_plugin "zsh-syntax-highlighting" "https://github.com/zsh-users/zsh-syntax-highlighting"

# Install Claude Code via native script
if ! command -v claude >/dev/null 2>&1; then
    echo ""
    echo "📦 Installing Claude Code via native installer..."
    curl -fsSL https://claude.ai/install.sh | bash
else
    echo "✓ Claude Code already installed"
fi

# Install Bun
if ! command -v bun >/dev/null 2>&1; then
    echo ""
    echo "📦 Installing Bun..."
    # Pretend to be bash to prevent modifying .zshrc
    SHELL=/bin/bash bash -c 'curl -fsSL https://bun.sh/install | bash'
else
    echo "✓ Bun already installed"
fi

#(Linux only)
{{ if eq .chezmoi.os "linux" -}}
# Install starship
if ! command -v starship >/dev/null 2>&1; then
    echo ""
    echo "📦 Installing starship..."
    curl -sS https://starship.rs/install.sh | sh
else
    echo "✓ starship already installed"
fi

# Install atuin
if ! command -v atuin >/dev/null 2>&1; then
    echo ""
    echo "📦 Installing atuin..."
    curl --proto '=https' --tlsv1.2 -sSf https://setup.atuin.sh | bash
else
    echo "✓ atuin already installed"
fi

# Install yazi
if ! command -v yazi >/dev/null 2>&1; then
    echo ""
    echo "📦 Installing yazi..."
    # Download latest release from GitHub
    YAZI_TEMP=$(mktemp -d)
    YAZI_VERSION=$(curl -s https://api.github.com/repos/sxyazi/yazi/releases/latest | grep '"tag_name"' | sed -E 's/.*"([^"]+)".*/\1/')
    curl -sL "https://github.com/sxyazi/yazi/releases/download/${YAZI_VERSION}/yazi-${YAZI_VERSION#v}-x86_64-unknown-linux-gnu.zip" -o "$YAZI_TEMP/yazi.zip"
    unzip -q "$YAZI_TEMP/yazi.zip" -d "$YAZI_TEMP"
    mkdir -p ~/.local/bin
    mv "$YAZI_TEMP/yazi-${YAZI_VERSION#v}-x86_64-unknown-linux-gnu/yazi" ~/.local/bin/
    rm -rf "$YAZI_TEMP"
    echo "✓ yazi installed"
else
    echo "✓ yazi already installed"
fi
{{- end -}}

echo ""
echo "✅ Essential tools synced!"
