#!/bin/bash
# =============================================================================
# Essential Tools Installation
# =============================================================================
# This script runs when its content changes (via run_onchange_ prefix)
# Use this for tools that should be kept up-to-date with config changes
# Hash: {{ include ".chezmoiscripts/run_onchange_after_01-install-tools.sh.tmpl" | sha256sum }}

set -euo pipefail

# Ensure PATH includes user binaries for tool detection
export PATH="$HOME/.local/bin:$PATH"

{{ if eq .chezmoi.os "darwin" -}}
# Install Homebrew (macOS only)
if ! command -v brew >/dev/null 2>&1; then
    echo "⚠️  Homebrew not found. Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

    # Add Homebrew to PATH for current session
    if [[ -d "/opt/homebrew" ]]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
    elif [[ -d "/usr/local/bin/brew" ]]; then
        eval "$(/usr/local/bin/brew shellenv)"
    fi
fi
{{- end }}

# Install Claude Code via native script
if ! command -v claude >/dev/null 2>&1; then
    echo ""
    echo "📦 Installing Claude Code via native installer..."
    curl -fsSL https://claude.ai/install.sh | bash
else
    echo "✓ Claude Code already installed"
fi

# Install Bun
if ! command -v bun >/dev/null 2>&1; then
    echo ""
    echo "📦 Installing Bun..."
    # Pretend to be bash to prevent modifying .zshrc
    SHELL=/bin/bash bash -c 'curl -fsSL https://bun.sh/install | bash'
else
    echo "✓ Bun already installed"
fi

#(Linux only)
{{ if eq .chezmoi.os "linux" -}}
# Detect system architecture
ARCH=$(uname -m)
# Neovim: aarch64 -> arm64
[ "$ARCH" = "aarch64" ] && NVIM_ARCH="arm64" || NVIM_ARCH="$ARCH"
# Yazi: uses aarch64 (no conversion needed)
YAZI_ARCH="$ARCH"

# Install starship
if ! command -v starship >/dev/null 2>&1; then
    echo ""
    echo "📦 Installing starship..."
    sudo curl -sS https://starship.rs/install.sh | sh -s -- -y
else
    echo "✓ starship already installed"
fi

# Install atuin
if ! command -v atuin >/dev/null 2>&1; then
    echo ""
    echo "📦 Installing atuin..."
    curl --proto '=https' --tlsv1.2 -LsSf https://setup.atuin.sh | sh -s -- --non-interactive
    # Link atuin to ~/.local/bin for PATH access
    ln -sf ~/.atuin/bin/atuin ~/.local/bin/atuin
else
    echo "✓ atuin already installed"
fi

# Install neovim latest (Linux only)
LATEST_VERSION=$(curl -s https://api.github.com/repos/neovim/neovim/releases/latest | grep '"tag_name"' | sed -E 's/.*"([^"]+)".*/\1/' | sed 's/v//')
CURRENT_VERSION=$(command -v nvim >/dev/null 2>&1 && nvim --version | grep -oP 'NVIM v\K[0-9.]+' || echo "none")

if [ "$CURRENT_VERSION" != "$LATEST_VERSION" ]; then
    echo ""
    if [ "$CURRENT_VERSION" != "none" ]; then
        echo "  Updating neovim $CURRENT_VERSION -> $LATEST_VERSION..."
    else
        echo "  Installing neovim $LATEST_VERSION..."
    fi
    sudo apt-get remove -y neovim 2>/dev/null || true
    # Remove old installation
    rm -rf ~/.local/nvim-*
    # Download and extract
    curl -sL "https://github.com/neovim/neovim/releases/latest/download/nvim-linux-${NVIM_ARCH}.tar.gz" | tar -xzf - -C ~/.local
    # Find extracted directory (all neovim builds use nvim-linux64)
    NVIM_DIR=$(find ~/.local -maxdepth 1 -type d -name "nvim-*" | head -1)
    rm -f ~/.local/bin/nvim
    ln -sf ${NVIM_DIR}/bin/nvim ~/.local/bin/nvim
    echo "  ✓ neovim $LATEST_VERSION installed"
fi

# Install yazi (terminal file manager)
if ! command -v yazi >/dev/null 2>&1; then
    echo ""
    echo "📦 Installing yazi..."
    YAZI_URL="https://github.com/sxyazi/yazi/releases/latest/download/yazi-${YAZI_ARCH}-unknown-linux-gnu.zip"
    # Remove old installation
    rm -rf ~/.local/yazi-*
    # Download to temp file and extract
    TEMP_ZIP=$(mktemp)
    curl -fsSL "$YAZI_URL" -o "$TEMP_ZIP"
    unzip -q -o "$TEMP_ZIP" -d ~/.local/
    rm -f "$TEMP_ZIP"
    # Find extracted directory and create symlinks
    YAZI_DIR=$(find ~/.local -maxdepth 1 -type d -name "yazi-*" | head -1)
    ln -sf "${YAZI_DIR}/yazi" ~/.local/bin/yazi
    ln -sf "${YAZI_DIR}/ya" ~/.local/bin/ya

    echo "  ✓ yazi installed"
else
    echo "✓ yazi already installed"
fi

# Install lazygit (Git TUI) - not in Debian repos
if ! command -v lazygit >/dev/null 2>&1; then
    echo ""
    echo "📦 Installing lazygit..."
    LAZYGIT_VERSION=$(curl -s "https://api.github.com/repos/jesseduffield/lazygit/releases/latest" | \grep -Po '"tag_name": *"v\K[^"]*')
    case "$ARCH" in
        x86_64) LAZYGIT_ARCH="x86_64" ;;
        aarch64|arm64) LAZYGIT_ARCH="arm64" ;;
        armv7l) LAZYGIT_ARCH="armv7" ;;
        *) echo "Unsupported architecture: $ARCH"; exit 1 ;;
    esac
    curl -Lo lazygit.tar.gz "https://github.com/jesseduffield/lazygit/releases/download/v${LAZYGIT_VERSION}/lazygit_${LAZYGIT_VERSION}_Linux_${LAZYGIT_ARCH}.tar.gz"
    tar xf lazygit.tar.gz lazygit
    install -D lazygit ~/.local/bin/lazygit
    rm -f lazygit lazygit.tar.gz
    echo "  ✓ lazygit ${LAZYGIT_VERSION} installed"
else
    echo "✓ lazygit already installed"
fi

{{- end }}

echo ""
echo "✅ Essential tools synced!"
