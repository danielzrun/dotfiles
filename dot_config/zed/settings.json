// Zed settings - Only non-default configurations
{
  "languages": {
    "Python": {
      "language_servers": [
        // Enable ty, disable basedpyright, and enable all
        // other registered language servers (ruff, pylsp, pyright).
        "ty",
        "!basedpyright",
        "!pyright",
        "!pylsp",
        "...",
      ],
    },
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },
  "title_bar": {
    "show_branch_icon": true,
  },
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "on_yank",
    "toggle_relative_line_numbers": true,
  },
  "terminal": {
    "font_family": ".ZedMono",
    "font_size": 16,
    "font_fallbacks": [
      "Symbols Nerd Font Mono",
      "PingFang SC"
    ],
  },
  "theme": {
    "mode": "dark",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },
  "ui_font_size": 16,
  "ui_font_fallbacks": [
    "Symbols Nerd Font",
    "PingFang SC"
  ],
  "buffer_font_size": 16,
  "buffer_font_family": ".ZedMono",
  "buffer_font_fallbacks": [
    "Symbols Nerd Font Mono",
    "PingFang SC"
  ],
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "tabs": {
    "file_icons": true,
  },
  "prettier": {
    "allowed": false,
  },
}
